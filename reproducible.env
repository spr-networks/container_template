# reproducible.env — pins for the container_template base image.
# Mirrors the shared pins in the super repo's reproducible.env. See that file and
# REPRODUCIBLE.md for how to bump a pin. Resolved: 2026-06-17

# Base image + CA-bundle donor (both pinned by multi-arch manifest digest)
UBUNTU_REF=ubuntu:24.04@sha256:786a8b558f7be160c6c8c4a54f9a57274f3b4fb1491cf65146521ae77ff1dc54
ALPINE_REF=alpine@sha256:28bd5fe8b56d1bd048e5babf5b10710ebe0bae67db86916198a6eec434943f8b

# Dockerfile frontend + BuildKit backend
DOCKERFILE_SYNTAX=docker/dockerfile:1@sha256:87999aa3d42bdc6bea60565083ee17e86d1f3339802f543c0d03998580f9cb89
BUILDKIT_REF=moby/buildkit:buildx-stable-1@sha256:0168606be2315b7c807a03b3d8aa79beefdb31c98740cebdffdfeebf31190c9f

# apt: Ubuntu snapshot archive timestamp (unified host: all arches + all pockets)
UBUNTU_SNAPSHOT=20260601T000000Z
